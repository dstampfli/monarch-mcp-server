# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored — never commit real credentials.
#
# login_setup.py loads this file automatically (via python-dotenv).

# Session cookie from a logged-in browser (recommended auth path).
# Copy the full value of the `cookie:` request header from DevTools
# (Network tab → a graphql/api.monarch.com request → Request Headers).
# Using this avoids pasting the long cookie into a terminal prompt, which
# macOS truncates at 1024 bytes per line.
#
# Put the whole thing on ONE line, quoted:
# MONARCH_COOKIE="session=...; __cf_bm=...; ..."

# Optional: pre-fill the email for the password login path (option 2).
# MONARCH_EMAIL="you@example.com"
